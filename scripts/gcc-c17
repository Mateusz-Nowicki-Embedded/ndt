#!/bin/sh
# Wrapper around the system GCC that forces -std=gnu17.
#
# GCC 15 defaults to C23 in which `false`, `true`, `bool` are reserved
# keywords; Linux kernels through v6.9 still define them as enum/typedef
# and won't compile.  KCFLAGS only feeds the main kernel build; smaller
# Makefiles (EFI stub, arch/x86/boot/compressed) define their own CFLAGS
# that don't propagate -std=.  Wrapping CC catches them all.
#
# Used by scripts/build-kernel.sh via `make CC=$NDT/scripts/gcc-c17`.

exec gcc -std=gnu17 "$@"
