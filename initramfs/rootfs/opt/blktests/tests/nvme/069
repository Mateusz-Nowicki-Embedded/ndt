#
# Clear CC.EN directly through the controller's BAR0 (via pcimem) while
# a fio randrw workload is running.  This bypasses the NVMe driver and
# emulates a "surprise" controller disable.  The kernel is expected to
# notice via in-flight I/O timeouts, run reset_work, and re-enumerate
# the controller and its namespace.
#
# Completion-delay injection (e.g. through the QEMU monitor) is expected
# to be applied externally during the 30 s window before the MMIO write.

. tests/nvme/rc

# pci-only test
nvme_trtype=pci

DESCRIPTION="surprise CC.EN=0 via MMIO - check driver recovers controller"
TIMED=1

NVME_CC_OFFSET=0x14

requires() {
	_nvme_requires
	_have_fio
	_have_program pcimem
}

device_requires() {
	_require_test_dev_is_nvme_pci
	_require_test_dev_is_not_nvme_multipath
}

test_device() {
	local nvmedev nvmectrl bdf bar0 state rc=0
	local fio_pid orig_io_timeout

	echo "Running ${TEST_NAME}"

	nvmedev=$(basename "$TEST_DEV")		# e.g. nvme0n1
	nvmectrl=${nvmedev%%n[0-9]*}		# e.g. nvme0
	bdf=$(_get_pci_dev_from_blkdev)
	bar0="/sys/bus/pci/devices/${bdf}/resource0"

	if [[ ! -e "$bar0" ]]; then
		echo "FAIL: ${bar0} not available"
		return 1
	fi

	# Shorten the I/O timeout so the driver notices the dead controller
	# in a few seconds instead of the 30 s default.  Restore afterwards.
	orig_io_timeout=$(cat /sys/module/nvme_core/parameters/io_timeout)
	echo 5 > /sys/module/nvme_core/parameters/io_timeout

	# Background fio: one randrw direct-I/O job per CPU keeps every
	# submission queue busy when the MMIO disable hits.
	fio --name=stress \
	    --filename="$TEST_DEV" \
	    --ioengine=libaio --direct=1 \
	    --rw=randrw --bs=4k --iodepth=32 \
	    --numjobs="$(nproc)" \
	    --time_based --runtime=90 \
	    --continue_on_error=all \
	    --group_reporting &> "$FULL" &
	fio_pid=$!

	sleep 30

	# Clear CC.EN behind the driver's back.  The QEMU NVMe model treats
	# the 1->0 transition on CC.EN as a controller reset (CSTS.RDY=0).
	if ! pcimem "$bar0" "$NVME_CC_OFFSET" w 0x00000000 &> /dev/null; then
		echo "FAIL: pcimem write to CC failed"
		rc=1
	fi

	# Wait for the kernel to detect the dead controller via I/O timeout
	# and rebuild it through reset_work.
	local timeout=90
	while ((timeout > 0)); do
		state=$(cat "/sys/class/nvme/${nvmectrl}/state" 2>/dev/null || echo unknown)
		if [[ "$state" == "live" && -b "$TEST_DEV" ]]; then
			break
		fi
		sleep 1
		timeout=$((timeout - 1))
	done

	if [[ "$state" != "live" ]]; then
		echo "FAIL: controller state is '${state}' (expected 'live')"
		rc=1
	fi
	if [[ ! -b "$TEST_DEV" ]]; then
		echo "FAIL: namespace ${TEST_DEV} did not re-appear after MMIO disable"
		rc=1
	fi
	if ! dd if="$TEST_DEV" of=/dev/null bs=4k count=1 iflag=direct \
		&> /dev/null; then
		echo "FAIL: post-recovery read from ${TEST_DEV} failed"
		rc=1
	fi

	{ kill "$fio_pid"; wait "$fio_pid"; } &> /dev/null

	echo "$orig_io_timeout" > /sys/module/nvme_core/parameters/io_timeout

	echo "Test complete"
	return $rc
}
