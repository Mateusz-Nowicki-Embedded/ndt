# Copyright (C) 2026 Mateusz Nowicki
#
# Reset the NVMe PCI controller while every MSI-X vector is masked
# from underneath the driver.
#
# Flow:
#   1) fio randrw runs in the background to keep the IO path busy
#   2) host masks all MSI-X vectors directly in BAR0 via pcimem,
#      bypassing the driver (sets PCI_MSIX_ENTRY_CTRL_MASKBIT)
#   3) test triggers `echo 1 > .../reset_controller`
#   4) verifies the controller comes back, a fresh admin command works,
#      and the device is healthy from the driver's POV
#
# Why this works without an HMP command:
#   QEMU's hw/pci/msix.c msix_notify() consults msix_is_masked() before
#   firing msi_send_message().  The mask bit lives in dev->msix_table[]
#   which is just the BAR0 region the kernel (and pcimem) can write.
#   See hw/nvme/ctrl.c: msix_init(... &n->bar0, 0, msix_table_offset ...).
#
# MSI-X table offset in BAR0 for this harness:
#   sizeof(NvmeBar) + 2 * (max_ioqpairs+1) * NVME_DB_SIZE  aligned to
#   4 KiB = 0x1000 + 2 * 9 * 4 -> 0x2000 for max_ioqpairs=8.
# Vector N's Vector Control reg lives at +16*N + 0xC.

. tests/nvme/rc

nvme_trtype=pci

DESCRIPTION="reset controller while all MSI-X vectors are masked"
QUICK=1

requires() {
	_nvme_requires
	_have_fio
	_have_program pcimem
}

device_requires() {
	_require_test_dev_is_nvme_pci
	_test_dev_has_no_metadata
}

# MSI-X table offset in BAR0 for our QEMU NVMe (max_ioqpairs=8,
# msix_exclusive_bar=off).  Stable while we don't change those params.
NDT_MSIX_TABLE_OFF=${NDT_MSIX_TABLE_OFF:-0x2000}

test_device() {
	echo "Running ${TEST_NAME}"

	local pdev sysfs nvmedev res0 m i n_vec off fio_pid fio_rc

	pdev=$(_get_pci_dev_from_blkdev)
	sysfs="/sys/bus/pci/devices/${pdev}/nvme"
	if [[ ! -d "$sysfs" ]]; then
		echo "$sysfs missing"
		return 1
	fi
	nvmedev=$(ls "$sysfs" | head -1)
	if [[ -z "$nvmedev" ]]; then
		echo "no nvme controller under $sysfs"
		return 1
	fi

	res0=/sys/bus/pci/devices/${pdev}/resource0
	if [[ ! -e "$res0" ]]; then
		echo "$res0 missing"
		return 1
	fi

	# Count MSI-X vectors used by the driver.  Linux NVMe names them
	# nvme<N>q<M> in /proc/interrupts (one per queue + admin).
	n_vec=$(grep -c "${nvmedev}q" /proc/interrupts || true)
	if (( n_vec < 1 )); then
		echo "no ${nvmedev} MSI-X vectors visible in /proc/interrupts"
		return 1
	fi

	# runtime sized so fio is still issuing IOs after the 20 s warm-up
	# plus the reset + recovery window.
	_run_fio_rand_io --filename="$TEST_DEV" --rw=randrw \
		--time_based --runtime=40 \
		--group_reporting &> /dev/null &
	fio_pid=$!

	# Let fio actually push IO for ~20 s before we cripple the IRQ path.
	sleep 20

	# Mask every vector by writing 0x1 to its Vector Control reg.
	for (( i = 0; i < n_vec; i++ )); do
		off=$(printf '0x%x' $(( NDT_MSIX_TABLE_OFF + 16 * i + 0xC )))
		pcimem "$res0" "$off" w 0x1 > /dev/null 2>&1 || true
	done

	# Reset.  Driver's nvme_reset_work tears down + re-creates the
	# admin queue and re-allocates MSI-X vectors via
	# pci_alloc_irq_vectors -- that re-init also clears the MSI-X
	# table, so our masks are wiped as part of the recovery path.
	echo 1 > "${sysfs}/${nvmedev}/reset_controller"

	# Let fio finish or error out (it may rc!=0 because some IO was
	# in flight during reset; that is expected for this scenario).
	wait "$fio_pid" 2>/dev/null
	fio_rc=$?

	# Wait for the block device to come back.
	for (( m = 0; m < 20; m++ )); do
		[[ -b "$TEST_DEV" ]] && break
		sleep 0.5
	done
	if (( m >= 20 )); then
		echo "$TEST_DEV did not come back after reset"
		return 1
	fi
	udevadm settle

	# Synchronous admin command verifies the freshly re-allocated
	# MSI-X path actually works -- a stuck vector would hang here.
	if ! nvme id-ctrl "$TEST_DEV" > /dev/null 2>&1; then
		echo "id-ctrl failed after reset (MSI-X path stuck?)"
		return 1
	fi

	# fio rc != 0 is informational, not a failure for this scenario.
	if (( fio_rc != 0 )); then
		echo "fio rc=${fio_rc} (expected — IO dropped during masked window)" \
			>> "${FULL}"
	fi

	echo "Test complete"
}
