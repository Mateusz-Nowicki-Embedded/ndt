# Copyright (C) 2026 Mateusz Nowicki
#
# Read an NVMe BAR0 register while PCI Memory Space Enable is disabled.
#
# Clearing Memory Space Enable (Command register bit 1, mask 0x02) makes the
# NVMe function stop decoding its memory BAR. A CPU MMIO read of a BAR0 register
# then becomes a PCIe Unsupported Request and the (x86) root complex synthesizes
# all-ones back to the load. This is the same all-ones signature the kernel uses
# to detect a dead/surprise-removed controller (CSTS == ~0).
#
# The nvme driver is unbound first so it does not observe all-ones on its own
# MMIO and tear the controller down while we toggle Memory Space Enable.
#
# NOTE: returning 0xFFFFFFFF on an Unsupported Request for a *memory* read is an
# x86 root-complex convention, not a PCIe spec guarantee (the spec only mandates
# it for configuration reads / the RP PIO path). Other architectures may instead
# raise an external abort / SError, so this test is restricted to x86_64.

. tests/nvme/rc

DESCRIPTION="read NVMe BAR0 register with PCI Memory Space Enable disabled"

# restrict test to nvme-pci only
nvme_trtype=pci

# NVMe controller register offset within BAR0 (NVMe base spec). VS (Version) is
# read-only and normally non-zero, so it is never legitimately 0xFFFFFFFF.
NVME_REG_VS=0x08

# Read a 32-bit register at offset $2 from resource file $1 via pcimem and echo
# the value as 0x........ (uppercase). Echoes nothing and returns non-zero on
# failure. All of pcimem's chatter is captured into $FULL, not stdout.
_pcimem_read32() {
	local resource="$1" off="$2"
	local out

	out="$(src/pcimem "$resource" "$off" w 2>>"$FULL")" || return 1
	echo "$out" >> "$FULL"
	echo "$out" | awk -F': ' '/^0x[0-9A-Fa-f]+: 0x[0-9A-Fa-f]+$/ {print $2}' | tail -1
}

requires() {
	_nvme_requires
	_have_program setpci
	if [[ ! -x src/pcimem ]]; then
		SKIP_REASONS+=("src/pcimem not built; run 'make' in the blktests root")
		return 1
	fi
	if [[ "$(uname -m)" != "x86_64" ]]; then
		SKIP_REASONS+=("test assumes x86 root-complex all-ones-on-UR behavior")
		return 1
	fi
}

device_requires() {
	_require_test_dev_is_nvme_pci
}

test_device() {
	echo "Running ${TEST_NAME}"

	local pdev resource
	local base off restored i rc=0

	pdev="$(_get_pci_dev_from_blkdev)"
	resource="/sys/bus/pci/devices/${pdev}/resource0"
	if [[ ! -r "$resource" ]]; then
		echo "BAR0 resource not available: ${resource}"
		return 1
	fi

	# If interrupted while the controller is detached, restore a sane state
	# (Memory Space Enable on, driver rebound). Cleared on the normal path below.
	trap 'setpci -s "${pdev}" COMMAND.w=2:2 2>/dev/null; echo -n "${pdev}" > /sys/bus/pci/drivers/nvme/bind 2>/dev/null; exit 1' INT TERM

	# Detach the nvme driver so it does not race the Memory Space Enable toggle.
	echo -n "${pdev}" > /sys/bus/pci/drivers/nvme/unbind

	# 1. Baseline: with Memory Space Enable set, VS must read a real value.
	base="$(_pcimem_read32 "$resource" "$NVME_REG_VS")"
	echo "VS with MSE on:   ${base:-<none>}" >> "$FULL"

	# 2. Clear Memory Space Enable (masked read-modify-write of bit 1 only).
	setpci -s "${pdev}" COMMAND.w=0:2
	off="$(_pcimem_read32 "$resource" "$NVME_REG_VS")"
	echo "VS with MSE off:  ${off:-<none>}" >> "$FULL"

	# 3. Restore Memory Space Enable unconditionally, then read back.
	setpci -s "${pdev}" COMMAND.w=2:2
	restored="$(_pcimem_read32 "$resource" "$NVME_REG_VS")"
	echo "VS after restore: ${restored:-<none>}" >> "$FULL"

	# Re-attach the nvme driver and wait for the namespace to reappear. State is
	# now restored, so drop the interrupt handler installed above.
	echo -n "${pdev}" > /sys/bus/pci/drivers/nvme/bind 2>/dev/null
	trap - INT TERM
	for ((i = 0; i < 20; i++)); do
		[[ -b ${TEST_DEV} ]] && break
		sleep .5
	done
	udevadm settle

	# Evaluate. Comparisons are case-folded since pcimem prints uppercase hex.
	if [[ -z "$base" || "${base^^}" == "0XFFFFFFFF" ]]; then
		echo "Test failed: invalid baseline VS read (${base:-<none>})"
		rc=1
	elif [[ "${off^^}" != "0XFFFFFFFF" ]]; then
		echo "Test failed: expected 0xFFFFFFFF with MSE off, got ${off:-<none>}"
		rc=1
	elif [[ "${restored^^}" != "${base^^}" ]]; then
		echo "Test failed: VS not restored (${restored:-<none>} != ${base})"
		rc=1
	elif [[ ! -b ${TEST_DEV} ]]; then
		echo "Test failed: ${TEST_DEV} did not come back after rebind"
		rc=1
	fi

	if [[ $rc -eq 0 ]]; then
		echo "Test complete"
	fi
	return $rc
}
