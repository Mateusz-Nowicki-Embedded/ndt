#!/bin/sh
# PID 1 for the QEMU initramfs.

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /run
mount -t debugfs none /sys/kernel/debug
mount -t tracefs none /sys/kernel/tracing 2>/dev/null || true

# /dev/fd needed for bash <(...) process substitution
ln -s /proc/self/fd /dev/fd 2>/dev/null
ln -s /proc/self/fd/0 /dev/stdin 2>/dev/null
ln -s /proc/self/fd/1 /dev/stdout 2>/dev/null
ln -s /proc/self/fd/2 /dev/stderr 2>/dev/null

export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
export TERM=linux

echo
echo "=== nvme QEMU rootfs ==="
echo "kernel: $(uname -r)"

# Load NVMe driver via modprobe (resolves nvme-core dep automatically from modules.dep).
#modprobe nvme && echo "[init] nvme loaded"

# Start udev daemon (multi-call binary: systemd-udevd is a symlink to udevadm).
# udev manages /dev nodes, populates /dev/disk/by-* links, settles after add events.
mkdir -p /run/udev
/usr/lib/systemd/systemd-udevd --daemon
udevadm trigger --action=add --type=subsystems
udevadm trigger --action=add --type=devices
udevadm settle --timeout=10
echo "[init] udev ready"

# NDT test mode: run a single blktests case if ndt_test=<id> is on the kernel
# cmdline (e.g. ndt_test=nvme/068), then power off so the host sees QEMU exit.
ndt_test=$(awk -v RS=' ' -F= '/^ndt_test=/{print $2}' /proc/cmdline | tr -d '\n')
# Optional: inner-iter count exported as $NDT_INNER_ITER for tests
# that loop reset scenarios inside one ./check invocation (e.g. 068).
ndt_inner_iter=$(awk -v RS=' ' -F= '/^ndt_inner_iter=/{print $2}' /proc/cmdline | tr -d '\n')
if [ -n "$ndt_inner_iter" ]; then
    export NDT_INNER_ITER=$ndt_inner_iter
fi
if [ -n "$ndt_test" ]; then
    echo "=== NDT_BEGIN test=$ndt_test ==="
    modprobe nvme
    # Burn the kernel's one-shot "capability attribute has been deprecated"
    # warning here so it doesn't land mid-test (nvme/039 last_dmesg | tail -2
    # would otherwise lose a real error line to this noise).
    cat /sys/block/*/capability > /dev/null 2>&1 || true

    # Hand control back to the host so it can program things that only make
    # sense once the driver has created I/O queues — e.g. per-SQ completion
    # delay via the QEMU monitor.  The host reads this sentinel from the
    # console socket, runs whatever HMP commands it wants, then writes a
    # line to /dev/ttyS1 to release us.  The line content is not parsed
    # today (any line unblocks); future commands can be added here.
    echo "=== NDT_PHASE phase='ready-for-cmd' ==="
    read -r _ctrl_line < /dev/ttyS1 || true
    echo "=== NDT_PHASE phase='running' ==="

    cd /opt/blktests
    ./check "$ndt_test"
    # blktests writes one result file per TEST_DEV — e.g. with
    # TEST_DEVS=(nvme0n2 nvme0n3) both results/nvme0n2/nvme/068 and
    # results/nvme0n3/nvme/068 are produced.  Aggregation rules:
    #   - any per-device "fail" wins   -> overall fail (with that reason)
    #   - else if any device passed    -> overall pass
    #   - else (all skipped/not run)   -> overall "not run"
    # blktests result format is TAB-separated: "<key>\t<value>"; values may
    # contain spaces (e.g. "not run").
    any_pass=0; any_fail=0; fail_reason=; skip_reason=
    for d in results/*/; do
        f="${d}${ndt_test}"
        [ -f "$f" ] || continue
        s=$(sed -n 's/^status\t//p' "$f" | head -1)
        r=$(sed -n 's/^reason\t//p' "$f" | head -1)
        case "$s" in
            pass)
                any_pass=1
                ;;
            "not run"|skipped|"")
                [ -z "$skip_reason" ] && skip_reason="$r"
                ;;
            *)
                any_fail=1
                [ -z "$fail_reason" ] && fail_reason="$r"
                ;;
        esac
    done
    if [ "$any_fail" = 1 ]; then
        result_status=fail
        result_reason=$fail_reason
    elif [ "$any_pass" = 1 ]; then
        result_status=pass
        result_reason=
    else
        result_status="not run"
        result_reason=$skip_reason
    fi
    echo "=== NDT_STATUS status='${result_status:-unknown}' reason='${result_reason:-}' ==="
    # dmesg only on non-pass: spares serial bandwidth and host console log.
    if [ "$result_status" != "pass" ]; then
        echo "=== NDT_DMESG_BEGIN ==="
        dmesg
        echo "=== NDT_DMESG_END ==="
    fi
    echo "=== NDT_END ==="
    poweroff -f
fi

echo "type 'poweroff -f' (or Ctrl+A x) to exit QEMU"
echo

exec /bin/sh
