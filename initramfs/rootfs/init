#!/bin/bash
# PID 1 for the QEMU initramfs.  Single-shot blktests runner with an
# interactive fallback when no test is requested.
#
# Flow:
#   1. mounts + udev + modprobe chain -> /dev/nvme0n1 backed by nvmet-pci-sw
#   2. parse ndt.test=NNN ndt.iter=K from /proc/cmdline
#   3. no ndt.test -> exec /bin/bash (interactive console, no auto-poweroff)
#   4. otherwise run ./check nvme/NNN K times, aggregate pass/fail/skip,
#      emit NDT_RESULT sentinel on ttyS0, poweroff -f
#
# Report format on ttyS0 (one line, parsed by host):
#   === NDT_RESULT pass=X fail=Y skip=Z iter=K test=nvme/NNN ===
#   === NDT_RESULT error='<reason>' ===

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /run
mount -t debugfs none /sys/kernel/debug
mount -t tracefs none /sys/kernel/tracing 2>/dev/null || true

ln -s /proc/self/fd /dev/fd 2>/dev/null
ln -s /proc/self/fd/0 /dev/stdin 2>/dev/null
ln -s /proc/self/fd/1 /dev/stdout 2>/dev/null
ln -s /proc/self/fd/2 /dev/stderr 2>/dev/null

export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
export TERM=linux

echo
echo "=== nvme QEMU rootfs ==="
echo "kernel: $(uname -r)"

mkdir -p /run/udev
/usr/lib/systemd/systemd-udevd --daemon
udevadm trigger --action=add --type=subsystems
udevadm trigger --action=add --type=devices
udevadm settle --timeout=10
echo "[init] udev ready"

# Host nvme driver is needed to bind to our software endpoint (nvmet-pci-sw
# exposes a fake NVMe device on bus 0xfe).  Loaded here so it's ready when
# the module brings the bridge up.
modprobe nvme

# Auto-build the nvmet target chain that backs our endpoint: null_blk
# provides the namespace, nvmet exposes it, nvmet-pci-sw plugs into both.
modprobe null_blk nr_devices=1
modprobe nvmet
mkdir -p /sys/kernel/config
mount -t configfs configfs /sys/kernel/config

#mkdir -p /sys/kernel/config/nvmet/subsystems/vnvme-ss
#echo 1 > /sys/kernel/config/nvmet/subsystems/vnvme-ss/attr_allow_any_host
#mkdir /sys/kernel/config/nvmet/subsystems/vnvme-ss/namespaces/1
#echo /dev/nullb0 > /sys/kernel/config/nvmet/subsystems/vnvme-ss/namespaces/1/device_path
#echo 1 > /sys/kernel/config/nvmet/subsystems/vnvme-ss/namespaces/1/enable

#exec /nvmve_load.sh

#mkdir /sys/kernel/config/nvmet/ports/1
#echo -n pci > /sys/kernel/config/nvmet/ports/1/addr_trtype
#ln -s /sys/kernel/config/nvmet/subsystems/vnvme-ss /sys/kernel/config/nvmet/ports/1/subsystems/vnvme-ss

exec /bin/bash
poweroff -f
