#!/bin/sh
# PID 1 for the QEMU initramfs.

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /run
mount -t debugfs none /sys/kernel/debug
mount -t tracefs none /sys/kernel/tracing 2>/dev/null || true

# /dev/fd needed for bash <(...) process substitution
ln -s /proc/self/fd /dev/fd 2>/dev/null
ln -s /proc/self/fd/0 /dev/stdin 2>/dev/null
ln -s /proc/self/fd/1 /dev/stdout 2>/dev/null
ln -s /proc/self/fd/2 /dev/stderr 2>/dev/null

export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
export TERM=linux

echo
echo "=== nvme QEMU rootfs ==="
echo "kernel: $(uname -r)"

# Load NVMe driver via modprobe (resolves nvme-core dep automatically from modules.dep).
#modprobe nvme && echo "[init] nvme loaded"

# Start udev daemon (multi-call binary: systemd-udevd is a symlink to udevadm).
# udev manages /dev nodes, populates /dev/disk/by-* links, settles after add events.
mkdir -p /run/udev
/usr/lib/systemd/systemd-udevd --daemon
udevadm trigger --action=add --type=subsystems
udevadm trigger --action=add --type=devices
udevadm settle --timeout=10
echo "[init] udev ready"

# NDT test mode: run a single blktests case if ndt_test=<id> is on the kernel
# cmdline (e.g. ndt_test=nvme/068), then power off so the host sees QEMU exit.
ndt_test=$(awk -v RS=' ' -F= '/^ndt_test=/{print $2}' /proc/cmdline | tr -d '\n')
if [ -n "$ndt_test" ]; then
    echo "=== NDT_BEGIN test=$ndt_test ==="
    modprobe nvme
    cd /opt/blktests
    ./check "$ndt_test"
    # Result file lives at results/<dev_name>/<test_name>, e.g. results/nvme0n2/nvme/032.
    result_file=""
    for d in results/*/; do
        if [ -f "${d}${ndt_test}" ]; then
            result_file="${d}${ndt_test}"
            break
        fi
    done
    # blktests result file is TAB-separated: "<key>\t<value>".  Values may
    # contain spaces (e.g. "not run"), so take everything after the first tab.
    if [ -n "$result_file" ]; then
        result_status=$(sed -n 's/^status\t//p' "$result_file" | head -1)
        result_reason=$(sed -n 's/^reason\t//p' "$result_file" | head -1)
    fi
    echo "=== NDT_STATUS status='${result_status:-unknown}' reason='${result_reason:-}' ==="
    echo "=== NDT_DMESG_BEGIN ==="
    dmesg
    echo "=== NDT_DMESG_END ==="
    echo "=== NDT_END ==="
    poweroff -f
fi

echo "type 'poweroff -f' (or Ctrl+A x) to exit QEMU"
echo

exec /bin/sh
